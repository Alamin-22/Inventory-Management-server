{
  "compilerOptions": {
    /* Base Configuration */
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2020", "DOM"],

    /* Strictness & Checks */
    "strict": true, // Enables all strict type checking options
    "noImplicitAny": true, // Error on 'any' types
    "strictNullChecks": true, // Stops you from accessing properties on null
    "noUnusedLocals": true, //  Error if you define a variable but don't use it
    "noUnusedParameters": true, //  Error if you define a function param but don't use it

    /* Module & Path Handling */
    "paths": {
      "@app/*": ["./src/app/*"],
      "@config/*": ["./src/config/*"],
      "@shared/*": ["./src/shared/*"],
      "@utils/*": ["./src/utils/*"]
    },

    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,

    /* Output */
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "skipLibCheck": true // Speeds up compilation by skipping checks inside node_modules
  },
  "include": ["src/**/*"], // simplified include
  "exclude": ["node_modules", "dist"]
}
